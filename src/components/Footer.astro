---
import Container from "./Container.astro";
import Social from './Social.astro';
const containerMaxWidth = "900px"
---

<footer>
  <Container {containerMaxWidth}>
    <div class="footer-links__grid">
      <ul>
        <li><strong>Чайна Хатинка</strong></li>
        <li>Наша Традиція</li>
        <li>Про нас</li>
      </ul>
      <ul>
        <li><strong>Крамничка</strong></li>
        <li>Про нашу крамничку</li>
        <li>Як замовити?</li>
      </ul>
      <ul>
        <li><strong>Читальня</strong></li>
        <li>Discord</li>
        <li>Contact Us</li>
      </ul>
    </div>
    <div class="footer-bottom__container">
      <p>&copy; 2014-{new Date().getFullYear()} TEAHUT.COM.UA</p>
      <Social />
    </div>
  </Container>
</footer>

<style>
  footer {
    /* position: relative;
    min-height: 200px; */
    background-color: var(--foreground);
    color: var(--background);
  }
  .footer-links__grid {
    padding: 3vh 0 7vh;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .footer-links__grid ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-links__grid ul li:first-of-type {
    margin-bottom: 0.5rem;
  }
  .footer-links__grid ul li strong {
    font-weight: 900;
  }
  .footer-bottom__container {
    position: relative;
    bottom: 0;
    padding: 0 0 1rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--step--2);
  }

  @media(max-width: 768px) {
    .footer-links__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media(max-width: 480px) {
    .footer-links__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer-bottom__container {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>